{
  "mcpServers": {
    "fledgling": {
      "command": "sh",
      "args": [
        "-c",
        "exec duckdb -init init/init-fledgling.sql"
      ],
      "cwd": "."
    },
    "blq_mcp": {
      "command": "blq",
      "args": [
        "mcp",
        "serve"
      ]
    },
    "jetsam": {
      "command": "jetsam",
      "args": [
        "serve"
      ],
      "type": "stdio"
    }
  }
}
